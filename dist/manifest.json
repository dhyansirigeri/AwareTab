{
  "manifest_version": 3,
  "name": "AURA",
  "version": "1.0",
  "description": "Intelligent, emotion-aware browser homepage.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "topSites",
    "tabs",
    "storage",
    "geolocation"
  ],
  "action": {
    "default_title": "AURA Settings"
  }
}
